{
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit*--no-gpg-sign*)",
      "Bash(curl *| sh*)",
      "Bash(curl *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(gh auth*)",
      "Bash(gh api*)",
      "Read(//etc/**)",
      "Read(//Users/cotopaxilyon/.ssh/**)",
      "Read(//Users/cotopaxilyon/.aws/**)",
      "Read(//Users/cotopaxilyon/Library/Keychains/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cotopaxilyon/WebstormProjects/Isobar/scripts/hooks/preToolUse-mode-manifest.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cotopaxilyon/WebstormProjects/Isobar/scripts/hooks/preToolUse-write-path.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cotopaxilyon/WebstormProjects/Isobar/scripts/hooks/preToolUse-diff-scanner.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "d=/Users/cotopaxilyon/WebstormProjects/Isobar/docs/qa-fail; t=$(grep -l 'status: *pending-review' \"$d\"/*.md 2>/dev/null | grep -v /README.md | xargs -n1 basename 2>/dev/null | sed 's/\\.md$//' | paste -sd, -); if [ -n \"$t\" ]; then jq -cn --arg t \"$t\" '{hookSpecificOutput:{hookEventName:\"UserPromptSubmit\",additionalContext:(\"⚠ Unreviewed QA Fail plans: \" + $t + \" — see docs/qa-fail/\")}}'; fi; exit 0"
          }
        ]
      }
    ]
  }
}
